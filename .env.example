# Sanity — public (safe to expose to browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity — server-only secrets (never expose to browser)
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token

# Optional: read-only token for draft-mode / live preview (browser-safe)
NEXT_PUBLIC_SANITY_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — email (Phase 7)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=contact@yourdomain.com

# Sanity webhook secret for ISR revalidation (Phase 9)
SANITY_REVALIDATE_SECRET=your_webhook_secret

# Sanity Studio Authentication
STUDIO_USERNAME=your_studio_username
STUDIO_PASSWORD=your_studio_password
